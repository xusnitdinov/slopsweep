# Session encryption (Auth.js)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# GitHub OAuth App — https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github (local)
#               https://YOUR_DOMAIN/api/auth/callback/github (production)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Optional locally; Vercel sets this automatically in production
AUTH_URL=http://localhost:3000

# Optional: richer AI README drafts (falls back to metadata generator)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
